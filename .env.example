# ─────────────────────────────────────────────────────
# FRIDAY Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────

# Gemini API (server-only — never exposed to browser)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase (server)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase (client — safe to expose, protected by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: custom API base for local dev with remote backend
# VITE_API_BASE=/api

# Optional: CORS allowlist for API routes (comma-separated, default "*")
# ALLOWED_ORIGINS=https://friday-visual-engine.vercel.app

# Optional: salt for IP-hashing in rate limiter
# IP_HASH_SALT=change_me
